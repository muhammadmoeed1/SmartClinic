# Server
PORT=3000
CORS_ORIGIN=http://localhost:5173

# Database
DB_HOST=localhost
DB_PORT=5432
DB_USER=smartclinic
DB_PASSWORD=smartclinic
DB_NAME=smartclinic

# JWT
JWT_ACCESS_SECRET=dev-access-secret-change-me
JWT_REFRESH_SECRET=dev-refresh-secret-change-me
JWT_ACCESS_TTL=900s
JWT_REFRESH_TTL=7d

# ── AI proxy ────────────────────────────────────────────────────────────────
# Leave AI_API_KEY empty to demo graceful degradation (static intake form etc).
#
# Option A — Anthropic Claude:
#   AI_PROVIDER=anthropic
#   AI_MODEL=claude-sonnet-5
#   AI_API_KEY=sk-ant-...
#
# Option B — OpenAI:
#   AI_PROVIDER=openai
#   AI_MODEL=gpt-4o
#   AI_API_KEY=sk-...
#
# Option C — Groq (free, OpenAI-compatible) — used by this project:
#   AI_PROVIDER=openai
#   AI_MODEL=llama-3.3-70b-versatile
#   AI_BASE_URL=https://api.groq.com/openai/v1
#   AI_API_KEY=gsk_...   (get a free key at https://console.groq.com)
AI_PROVIDER=openai
AI_MODEL=llama-3.3-70b-versatile
AI_BASE_URL=https://api.groq.com/openai/v1
AI_API_KEY=

# File uploads
UPLOAD_DIR=./uploads
